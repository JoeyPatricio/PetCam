# Email notification config — copy this file to .env and fill in your values
# Uses Gmail SMTP with an App Password (no Twilio needed, completely free)
#
# How to get a Gmail App Password:
#   1. Go to myaccount.google.com → Security → 2-Step Verification (must be ON)
#   2. Search "App passwords" → create one named "BunnyCam"
#   3. Paste the 16-character password below

EMAIL_USER=your.gmail@gmail.com       # Gmail address you send FROM
EMAIL_PASS=xxxx xxxx xxxx xxxx        # 16-char App Password (spaces ok)
NOTIFY_TO=your.phone@carrier.com      # Where to send alerts (see below)

# ── SMS-via-email gateways (free, no account needed) ──────────────────────
# Replace 10digitnumber with your actual number, no dashes
#   AT&T:      10digitnumber@txt.att.net
#   T-Mobile:  10digitnumber@tmomail.net
#   Verizon:   10digitnumber@vtext.com
#   Sprint:    10digitnumber@messaging.sprintpcs.com
# Or just use a regular email address to receive alerts in your inbox.

# Cooldown between alerts per behavior (minutes), default 10
NOTIFY_COOLDOWN_MINUTES=10
